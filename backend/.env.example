NODE_ENV=production
PORT=5055

FRONTEND_URL=https://your-vercel-app.vercel.app

# Supabase has been removed — no Supabase env vars required

ACTIVE_DB_PROVIDER=mysql

# MySQL — mas_hrms database
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=mas_hrms
DB_POOL_MAX=10

# Portal JWT — generate: openssl rand -hex 32
PORTAL_JWT_SECRET=change-me-to-random-32-char-string
JWT_SECRET=change-me-to-random-32-char-string

# NCOSEC Biometric DB (Matrix Cosec SQL Server)
NCOSEC_DB_HOST=172.10.10.146
NCOSEC_DB_PORT=1433
NCOSEC_DB_USER=your-ncosec-user
NCOSEC_DB_PASSWORD=your-ncosec-password
NCOSEC_DB_NAME=NCOSEC
NCOSEC_DB_ENCRYPT=false

# Payroll / encryption secrets
PAYROLL_BANK_KEY=change-me-secure-bank-key
COMM_SECRET=change-me-secure-communication-secret

# HRMS invite / reset email SMTP
# Gmail/Google Workspace: use App Password, not normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hrms@mascallnet.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM=hrms@mascallnet.com
SMTP_FROM_NAME=MAS Callnet HRMS

# Legacy SQL Server Database
LEGACY_MSSQL_HOST=192.168.10.22
LEGACY_MSSQL_PORT=1433
LEGACY_MSSQL_DATABASE=db_bill
LEGACY_MSSQL_USER=hrms_readonly
LEGACY_MSSQL_PASSWORD=<your-password>
LEGACY_MSSQL_ENCRYPT=false
LEGACY_MSSQL_TRUST_CERT=true

# Legacy Sync Configuration
LEGACY_SYNC_ENABLED=false
LEGACY_SYNC_INTERVAL_MS=60000
LEGACY_SYNC_BATCH_SIZE=1000
LEGACY_SYNC_PARALLEL_DOMAINS=true
LEGACY_SYNC_MAX_RETRIES=3
LEGACY_SYNC_RETRY_DELAY_MS=5000
LEGACY_CT_RETENTION_DAYS=2
