    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "handlebars": "^4.7.9",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "mssql": "^12.5.5",
    "multer": "^2.1.1",
    "mysql2": "^3.11.5",
    "nodemailer": "^8.0.11",
