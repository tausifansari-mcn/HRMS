    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@types/twilio": "^3.19.2",
    "@vitest/coverage-v8": "^4.1.7",
    "ssh2": "^1.17.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.7"
