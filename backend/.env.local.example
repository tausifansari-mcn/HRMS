# =============================================================
# Backend — Local Development Environment
# Copy to backend/.env and fill in real values before starting.
# =============================================================

NODE_ENV=development
PORT=5055

# Frontend origin — used for CORS and password reset links
FRONTEND_URL=http://localhost:8080

ACTIVE_DB_PROVIDER=mysql

# ── Main HRMS Database (MySQL) ────────────────────────────────
# Use DB_HOST=localhost for direct Node.js run
# Use DB_HOST=mysql for Docker Compose deployment
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=mas_hrms
DB_POOL_MAX=10

# ── JWT Secrets ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
PORTAL_JWT_SECRET=local-dev-jwt-secret-change-in-production-32
JWT_SECRET=local-dev-jwt-secret-change-in-production-32chars

# ── Encryption Keys ───────────────────────────────────────────
# At least 16 characters. Generate with: openssl rand -hex 24
PAYROLL_BANK_KEY=local-dev-bank-key-16c
COMM_SECRET=local-dev-comm-secret-16ch

# ── SMTP (Optional — leave blank to disable email) ────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost
SMTP_FROM_NAME=MAS Callnet HRMS

# ── NCOSEC Biometric DB (Optional — leave blank if not used) ──
NCOSEC_DB_HOST=
NCOSEC_DB_PORT=1433
NCOSEC_DB_USER=
NCOSEC_DB_PASSWORD=
NCOSEC_DB_NAME=NCOSEC
NCOSEC_DB_ENCRYPT=false

# ── Dialer DB (Optional — leave blank if not used) ────────────
DIALER_DB_HOST=
DIALER_DB_PORT=3306
DIALER_DB_USER=
DIALER_DB_PASSWORD=
DIALER_DB_NAME=

# ── Demo / Bypass (safe for local dev only) ───────────────────
PORTAL_DEMO_BYPASS=true
INTERNAL_DEMO_BYPASS=true

# ── Scheduler control ─────────────────────────────────────────
# Set to "true" to enable background workers (set to false for simpler local dev)
ENABLE_SCHEDULERS=false

# ── Demo data seed ────────────────────────────────────────────
# Set to "true" to seed demo data on first migration (local dev only)
SEED_DEMO_DATA=true

# ── Legacy MySQL Sync ─────────────────────────────────────────
LEGACY_SYNC_ENABLED=false
LEGACY_SYNC_INTERVAL_MS=60000
LEGACY_SYNC_BATCH_SIZE=1000
LEGACY_SYNC_PARALLEL_DOMAINS=true
LEGACY_SYNC_MAX_RETRIES=3
LEGACY_SYNC_RETRY_DELAY_MS=5000
LEGACY_CT_RETENTION_DAYS=2
