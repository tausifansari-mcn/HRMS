# =============================================================
# .env.mysql.example
# Copy to .env and fill in real values before starting.
# This configuration is for PURE MySQL local Docker deployment.
# NO Supabase, NO PostgreSQL, NO Kong, NO external services.
# =============================================================

# ── Node Environment ──────────────────────────────────────────
NODE_ENV=development

# ── Frontend URL for CORS and password reset links ────────────
FRONTEND_URL=http://localhost:8080

# ── Active Database Provider ──────────────────────────────────
ACTIVE_DB_PROVIDER=mysql

# ── MySQL Database Configuration ──────────────────────────────
# These values are used by both docker-compose AND the backend
DB_ROOT_PASSWORD=rootpassword
DB_HOST=mysql
DB_PORT=3306
DB_USER=hrms_user
DB_PASSWORD=hrms_password
DB_NAME=mas_hrms
DB_POOL_MAX=10

# ── JWT Secrets ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
PORTAL_JWT_SECRET=change-me-please-use-32-char-random-string
JWT_SECRET=change-me-please-use-32-char-random-string

# ── Encryption Keys ───────────────────────────────────────────
# At least 16 characters. Generate with: openssl rand -hex 24
PAYROLL_BANK_KEY=change-me-bank-key-16ch
COMM_SECRET=change-me-comm-secret-16ch

# ── SMTP Configuration ────────────────────────────────────────
# Gmail: use an App Password (not your Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=MAS Callnet HRMS

# ── NCOSEC Biometric DB (Matrix Cosec SQL Server) ─────────────
# Leave blank if biometric integration is not used locally.
NCOSEC_DB_HOST=
NCOSEC_DB_PORT=1433
NCOSEC_DB_USER=
NCOSEC_DB_PASSWORD=
NCOSEC_DB_NAME=NCOSEC
NCOSEC_DB_ENCRYPT=false

# ── Dialer DB (READ-ONLY call data integration) ───────────────
# Leave blank if dialer integration is not used locally.
DIALER_DB_HOST=
DIALER_DB_PORT=3306
DIALER_DB_USER=
DIALER_DB_PASSWORD=
DIALER_DB_NAME=

# ── Demo / Bypass (never true in production) ──────────────────
PORTAL_DEMO_BYPASS=false
INTERNAL_DEMO_BYPASS=false

# ── Scheduler control ─────────────────────────────────────────
# Set to "true" to start tenure, communication cleanup,
# attendance sweep, and legacy sync workers on startup.
ENABLE_SCHEDULERS=false

# ── Demo data seed ────────────────────────────────────────────
# Set to "true" to run 043_demo_data.sql during first migration.
# Only for local dev. Never enable in production.
SEED_DEMO_DATA=false

# ── Legacy MySQL Sync ─────────────────────────────────────────
LEGACY_SYNC_ENABLED=false
LEGACY_SYNC_INTERVAL_MS=60000
LEGACY_SYNC_BATCH_SIZE=1000
LEGACY_SYNC_PARALLEL_DOMAINS=true
LEGACY_SYNC_MAX_RETRIES=3
LEGACY_SYNC_RETRY_DELAY_MS=5000
LEGACY_CT_RETENTION_DAYS=2
