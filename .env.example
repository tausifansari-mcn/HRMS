# ===========================================
# HRMS Frontend — Environment Variables
# Copy this file to .env.local and fill in your values
# ===========================================

# Backend API URL
# For local deployment: http://localhost:5055 (or whatever port your backend runs on)
# Leave as http://localhost:5055 for running both frontend and backend on the same machine
VITE_HRMS_API_URL=http://localhost:5055

# Feature flags — keep all as "backend" for MySQL deployment
VITE_HRMS_EMPLOYEES=backend
VITE_HRMS_ATTENDANCE=backend
VITE_HRMS_WFM=backend
VITE_HRMS_LEAVE=backend
VITE_HRMS_PAYROLL=backend
VITE_HRMS_ATS=backend
VITE_HRMS_INTEGRATION=backend
VITE_HRMS_KPI=backend

# Optional: LMS integration (leave blank if not using LMS)
VITE_LMS_API_URL=

# Optional: Push notifications (leave blank to disable)
VITE_VAPID_PUBLIC_KEY=

# Optional: Demo login override (leave blank for production)
# Set to "true" only for demo/testing environments
VITE_ENABLE_DEMO_LOGIN=
